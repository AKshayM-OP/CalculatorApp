<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="CalcButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">90dp</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:layout_margin">2dp</item>
        <item name="cornerRadius">4dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="backgroundTint">#333333</item>
    </style>

    <style name="OpButtonStyle" parent="CalcButtonStyle">
        <item name="backgroundTint">#FF9800</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>
</resources>